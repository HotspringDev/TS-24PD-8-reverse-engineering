<Application
	x:Class="T2208.App"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:ViewModels="clr-namespace:T2208.ViewModels"
	xmlns:options="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
	xmlns:jCustomControls="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib"
	xmlns:local="clr-namespace:T2208">
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary
					Source="Language\StringResource.zh-CN.xaml" />
				<ResourceDictionary
					Source="Language\StringResource.en-US.xaml" />
				<ResourceDictionary
					Source="Styles\Icons.xaml" />
				<ResourceDictionary
					Source="Styles/BrushStyle.xaml" />
				<ResourceDictionary
					Source="Resource\ImageResource.xaml" />
				<ResourceDictionary
					Source="Resource\ViewModelResource.xaml" />
				<ResourceDictionary
					Source="Resource\ConstResource.xaml" />
				<ResourceDictionary
					Source="Styles\ControlStyle.xaml" />
				<ResourceDictionary
					Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
				<ResourceDictionary
					Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
				<ResourceDictionary
					Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
				<ResourceDictionary
					Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Primary/MaterialDesignColor.Blue.xaml" />
				<ResourceDictionary
					Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Accent/MaterialDesignColor.Red.xaml" />
				<ResourceDictionary
					Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
				<ResourceDictionary
					Source="pack://application:,,,/SEIKAKU.WPF.Theme;component/ThemeManager.xaml" />
				<ResourceDictionary
					Source="pack://application:,,,/T2208;component/Resource/24.12.Resource.xaml" />
				<ResourceDictionary
					Source="pack://application:,,,/T2208;component/Resource/ConstResource.xaml" />
			</ResourceDictionary.MergedDictionaries>
			<SolidColorBrush
				x:Key="BlackColorBrush"
				Color="#AA000000" />
			<SolidColorBrush
				x:Key="Border.Background"
				Color="#3d3d3d" />
			<BitmapImage
				x:Key="ImageGeqSliderThumb"
				UriSource="Resource/thumb_new.png"
				Rotation="Rotate270" />
			<Style
				x:Key="SwitcherRed"
				TargetType="{x:Type jCustomControls:JSwitcher}">
				<Setter
					Property="FrameworkElement.Cursor"
					Value="Hand" />
				<Setter
					Property="jCustomControls:JSwitcher.ActiveBackgroundBrush"
					Value="#FFFF0000" />
				<Setter
					Property="jCustomControls:JSwitcher.InactiveBackgroundBrush"
					Value="#FF808080" />
				<Setter
					Property="jCustomControls:JSwitcher.ActiveForegroundBrush"
					Value="#FFFFFFFF" />
				<Setter
					Property="jCustomControls:JSwitcher.InactiveForegroundBrush"
					Value="#FF000000" />
				<Setter
					Property="FontFamily"
					Value="Segoe UI, Lucida Sans Unicode, Verdana" />
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type jCustomControls:JSwitcher}">
							<Grid
								Name="grid">
								<Border
									x:Name="BD"
									CornerRadius="3"
									Effect="{DynamicResource Effect_Normal}"
									Background="{TemplateBinding Control.Background}" />
								<Border
									Name="styleBorder"
									Background="{DynamicResource Brush_Stereoscopic}"
									CornerRadius="{Binding ElementName=BD, Path=CornerRadius}">
									<ContentControl
										Margin="{TemplateBinding Control.Padding}"
										HorizontalAlignment="Center"
										VerticalAlignment="Center"
										Content="{TemplateBinding ContentControl.Content}" />
								</Border>
							</Grid>
							<ControlTemplate.Triggers>
								<Trigger
									Property="ToggleButton.IsChecked"
									Value="true">
									<Setter
										TargetName="grid"
										Property="Margin"
										Value="0 2 0 -2" />
									<Setter
										Property="Foreground"
										Value="#FFFFFFFF" />
									<Setter
										TargetName="BD"
										Value="{DynamicResource Effect_IsChecked}"
										Property="UIElement.Effect" />
								</Trigger>
								<Trigger
									Property="IsEnabled"
									Value="False">
									<Setter
										Property="UIElement.Opacity"
										Value="0.50" />
									<Setter
										TargetName="BD"
										Property="UIElement.Effect"
										Value="{x:Null}" />
								</Trigger>
								<Trigger
									Property="IsPressed"
									Value="True">
									<Setter
										Property="Foreground"
										Value="#FFFFFFFF" />
									<Setter
										TargetName="grid"
										Property="Margin"
										Value="0 3 0 -3" />
									<Setter
										TargetName="BD"
										Value="{DynamicResource Effect_IsPressed}"
										Property="UIElement.Effect" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style
				x:Key="Slider.Vertical"
				TargetType="{x:Type jCustomControls:JSlider}">
				<Setter
					Property="HorizontalAlignment"
					Value="Center" />
				<Setter
					Property="jCustomControls:JSlider.Orientation"
					Value="Vertical" />
				<Setter
					Property="jCustomControls:JSlider.IsExteriorEnable"
					Value="True" />
				<Setter
					Property="jCustomControls:JSlider.ThumbImage"
					Value="{DynamicResource Image_SliderThumb}" />
				<Setter
					Property="jCustomControls:JSlider.ThumbImageHeight"
					Value="20" />
				<Setter
					Property="jCustomControls:JSlider.ThumbImageWidth"
					Value="10" />
			</Style>
			<Style
				x:Key="ImageButtonStyle"
				TargetType="{x:Type Button}">
				<Setter
					Property="FrameworkElement.FocusVisualStyle"
					Value="{StaticResource FocusVisual}" />
				<Setter
					Property="Background"
					Value="#00FFFFFF" />
				<Setter
					Property="Foreground"
					Value="{StaticResource Base.Foreground}" />
				<Setter
					Property="BorderThickness"
					Value="0" />
				<Setter
					Property="HorizontalContentAlignment"
					Value="Center" />
				<Setter
					Property="VerticalContentAlignment"
					Value="Center" />
				<Setter
					Property="FrameworkElement.Cursor"
					Value="Hand" />
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type Button}">
							<Border
								x:Name="border"
								BorderBrush="{TemplateBinding Control.BorderBrush}"
								BorderThickness="{TemplateBinding Control.BorderThickness}"
								Background="{TemplateBinding Control.Background}"
								SnapsToDevicePixels="True">
								<ContentPresenter
									x:Name="contentPresenter"
									Focusable="False"
									HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
									Margin="{TemplateBinding Control.Padding}"
									RecognizesAccessKey="True"
									SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"
									VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger
									Property="IsEnabled"
									Value="False">
									<Setter
										Property="UIElement.Opacity"
										Value=".56" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style
				x:Key="TabPanelStyle"
				TargetType="{x:Type jCustomControls:TabPanelListBox}">
				<Setter
					Property="ItemsPanel">
					<Setter.Value>
						<ItemsPanelTemplate>
							<UniformGrid
								Rows="2" />
						</ItemsPanelTemplate>
					</Setter.Value>
				</Setter>
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type jCustomControls:TabPanelListBox}">
							<Border
								HorizontalAlignment="Stretch"
								Padding="{TemplateBinding Control.Padding}"
								Width="{TemplateBinding FrameworkElement.Width}"
								Height="{TemplateBinding FrameworkElement.Height}"
								BorderBrush="{TemplateBinding Control.BorderBrush}"
								BorderThickness="{TemplateBinding Control.BorderThickness}"
								Background="{TemplateBinding Control.Background}">
								<ItemsPresenter />
							</Border>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style
				x:Key="TabPanelItemButton.NoStyle"
				TargetType="{x:Type jCustomControls:TabPanelListBoxItem}">
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type jCustomControls:TabPanelListBoxItem}">
							<ContentPresenter
								HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
								RecognizesAccessKey="True"
								SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"
								VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}" />
							<ControlTemplate.Triggers>
								<Trigger
									Property="IsEnabled"
									Value="False">
									<Setter
										Property="UIElement.Opacity"
										Value="0.23" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
		</ResourceDictionary>
	</Application.Resources>
</Application>
