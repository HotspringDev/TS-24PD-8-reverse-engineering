<UserControl
	x:Class="T2208.DialogWindows.MessageDialog"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
	xmlns:domain="clr-namespace:T2208.Domain"
	xmlns:system="clr-namespace:System;assembly=mscorlib"
	MaxWidth="600"
	xmlns:dialogwindows="clr-namespace:T2208.DialogWindows">
	<StackPanel
		Margin="16">
		<TextBlock
			Name="Title"
			Text="{Binding CurrentData[Title]}" />
		<TextBlock
			x:Name="Message"
			Margin="0 8 0 0"
			TextWrapping="Wrap"
			HorizontalAlignment="Stretch"
			Text="{Binding CurrentData[Message]}" />
		<StackPanel
			Orientation="Horizontal"
			HorizontalAlignment="Right">
			<Button
				Style="{StaticResource MaterialDesignFlatButton}"
				IsDefault="True"
				Margin="0 8 8 0"
				Content="{DynamicResource Str_Confirm_DS}"
				Command="materialDesign:DialogHost.CloseDialogCommand">
				<ButtonBase.CommandParameter>
					<system:Boolean
						xmlns:system="clr-namespace:System;assembly=mscorlib">True</system:Boolean>
				</ButtonBase.CommandParameter>
			</Button>
			<Button
				Content="{DynamicResource Str_Cancel_DS}"
				Style="{StaticResource MaterialDesignFlatButton}"
				IsCancel="True"
				Margin="0 8 8 0"
				Command="materialDesign:DialogHost.CloseDialogCommand">
				<ButtonBase.CommandParameter>
					<system:Boolean
						xmlns:system="clr-namespace:System;assembly=mscorlib">False</system:Boolean>
				</ButtonBase.CommandParameter>
			</Button>
		</StackPanel>
	</StackPanel>
</UserControl>
