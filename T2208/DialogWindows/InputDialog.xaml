<UserControl
	x:Class="T2208.DialogWindows.InputDialog"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
	xmlns:system="clr-namespace:System;assembly=mscorlib"
	xmlns:domain="clr-namespace:T2208.Domain"
	xmlns:dialogWindows="clr-namespace:T2208.DialogWindows">
	<Grid
		Margin="16">
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
		</Grid.RowDefinitions>
		<TextBlock
			Name="Title"
			Text="{Binding Title}" />
		<TextBox
			Name="PresetName"
			Style="{DynamicResource MaterialDesignFloatingHintTextBox}"
			Margin="0 6 0 0"
			FontSize="18"
			Grid.Row="1"
			materialDesign:HintAssist.Hint="{Binding HintName}" />
		<StackPanel
			Orientation="Horizontal"
			Grid.Row="2"
			Margin="0 16 0 0">
			<Button
				IsDefault="True"
				Style="{DynamicResource MaterialDesignFlatButton}"
				Content="{DynamicResource Str_Confirm_DS}"
				Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}">
				<ButtonBase.CommandParameter>
					<system:Boolean>True</system:Boolean>
				</ButtonBase.CommandParameter>
			</Button>
			<Button
				IsCancel="True"
				Margin="8 0 0 0"
				Style="{DynamicResource MaterialDesignFlatButton}"
				Content="{DynamicResource Str_Cancel_DS}"
				Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}">
				<ButtonBase.CommandParameter>
					<system:Boolean>False</system:Boolean>
				</ButtonBase.CommandParameter>
			</Button>
		</StackPanel>
	</Grid>
</UserControl>
