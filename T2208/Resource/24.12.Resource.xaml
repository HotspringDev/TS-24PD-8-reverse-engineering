<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<ImageBrush
		x:Key="Base.Border.Background.ImageBrush"
		ImageSource="MidBorderBackground.png" />
	<Style
		x:Key="Base.Border.Background.Style"
		TargetType="{x:Type Border}">
		<Setter
			Property="Border.CornerRadius"
			Value="3" />
		<Setter
			Property="Background"
			Value="{StaticResource Base.Border.Background.ImageBrush}" />
	</Style>
</ResourceDictionary>
