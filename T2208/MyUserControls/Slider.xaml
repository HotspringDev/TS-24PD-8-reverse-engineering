<UserControl
	x:Class="T2208.MyUserControls.Slider"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:T2208.MyUserControls"
	xmlns:converters="clr-namespace:T2208.MyConverters"
	x:Name="ks"
	MouseWheel="Thumb_MouseWheel"
	IsEnabledChanged="Ks_IsEnabledChanged">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<converters:GEQConverter
				x:Key="GEQConverter" />
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Canvas>
		<Thumb
			x:Name="thumb"
			Cursor="Hand"
			DragDelta="Thumb_DragDelta"
			DragCompleted="Thumb_DragCompleted">
			<Control.Background>
				<ImageBrush />
			</Control.Background>
			<Control.Template>
				<ControlTemplate
					TargetType="{x:Type Thumb}">
					<Image
						x:Name="image"
						Stretch="Fill">
						<Image.Source>
							<MultiBinding
								Converter="{StaticResource GEQConverter}">
								<Binding
									ElementName="ks"
									Path="ThumbImage" />
								<Binding
									ElementName="ks"
									Path="LastUpdateThumb" />
								<Binding
									ElementName="ks"
									Path="IsLastUpdate" />
							</MultiBinding>
						</Image.Source>
					</Image>
				</ControlTemplate>
			</Control.Template>
		</Thumb>
	</Canvas>
</UserControl>
