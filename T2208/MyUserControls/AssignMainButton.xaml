<UserControl
	x:Class="T2208.MyUserControls.AssignMainButton"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:JCustomControl="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib"
	xmlns:ViewModels="clr-namespace:T2208.ViewModels"
	xmlns:local="clr-namespace:T2208.MyUserControls"
	xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity">
	<Border>
		<FrameworkElement.Style>
			<Style
				TargetType="{x:Type Border}">
				<Setter
					Property="Background"
					Value="#00FFFFFF" />
				<Setter
					Property="BorderThickness"
					Value="2" />
				<Setter
					Property="BorderBrush"
					Value="#00FFFFFF" />
				<Style.Triggers>
					<Trigger
						Property="UIElement.IsMouseOver"
						Value="True">
						<Setter
							Property="BorderBrush"
							Value="#FF00FF00" />
					</Trigger>
				</Style.Triggers>
			</Style>
		</FrameworkElement.Style>
		<UniformGrid
			Columns="1"
			Margin="8">
			<DockPanel>
				<TextBlock
					HorizontalAlignment="Center"
					Foreground="#FFFFFFFF"
					FontSize="12"
					Margin="0,0,0,5"
					Width="40"
					Text="{Binding ChannelName}" />
				<JCustomControl:JSwitcher
					Width="60"
					HorizontalAlignment="Right"
					IsChecked="{Binding AssignMain}"
					Command="{Binding AssignMainCommand}"
					Content="{Binding AssignMain, Converter='{x:Static ViewModels:ConverterProvider.BoolToStringConverter}', ConverterParameter=ON|OFF}" />
			</DockPanel>
			<Grid
				Margin="0,5,0,0"
				Height="20"
				Row="1"
				Width="150">
				<JCustomControl:LedSlider
					Cursor="Hand"
					Mar="2"
					Effect="{DynamicResource Effect_Normal}"
					Tag="1"
					MaxLedNum="24"
					LedNum="{Binding PanValue, Mode=TwoWay}"
					SliderValueChanged="LedSlider_SliderValueChanged">
					<i:Interaction.Triggers>
						<i:EventTrigger
							EventName="MouseMove">
							<i:InvokeCommandAction
								Command="{Binding PanValueChangeCommand}" />
						</i:EventTrigger>
						<i:EventTrigger
							EventName="MouseDown">
							<i:InvokeCommandAction
								Command="{Binding PanValueChangeCommand}" />
						</i:EventTrigger>
					</i:Interaction.Triggers>
				</JCustomControl:LedSlider>
				<Border
					IsHitTestVisible="False"
					Background="{StaticResource Brush_Stereoscopic}" />
			</Grid>
		</UniformGrid>
	</Border>
</UserControl>
