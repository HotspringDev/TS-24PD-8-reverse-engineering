<UserControl
	x:Class="T2208.MyUserControls.RouterFader"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:T2208.MyUserControls"
	xmlns:JCustomControls="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib"
	xmlns:ViewModel="clr-namespace:T2208.ViewModels">
	<Border
		Visibility="{Binding ItemEnabled, Converter='{x:Static ViewModel:ConverterProvider.BoolToVisibilityConverter}', ConverterParameter=Collapsed}">
		<FrameworkElement.Style>
			<Style
				TargetType="{x:Type Border}">
				<Setter
					Property="Background"
					Value="#00FFFFFF" />
				<Setter
					Property="BorderThickness"
					Value="2" />
				<Setter
					Property="BorderBrush"
					Value="#00FFFFFF" />
				<Style.Triggers>
					<Trigger
						Property="UIElement.IsMouseOver"
						Value="True">
						<Setter
							Property="BorderBrush"
							Value="#FF00FF00" />
					</Trigger>
				</Style.Triggers>
			</Style>
		</FrameworkElement.Style>
		<StackPanel
			Margin="3">
			<TextBlock
				Name="titlelabel"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				Foreground="#FFFFFFFF"
				Height="20"
				Text="{Binding ChName}" />
			<JCustomControls:JSlider
				Style="{StaticResource Slider_Vertical}"
				IsUIFireEventDirectly="True"
				Height="80"
				Maximum="80"
				Margin="0,0,0,2"
				Value="{Binding Value, Mode=TwoWay}"
				SendValue="{Binding SendValue, Mode=TwoWay}"
				SendValueChanged="JSlider_SendValueChanged" />
			<Label
				Name="valuetext"
				RenderOptions.EdgeMode="Aliased"
				SnapsToDevicePixels="False"
				HorizontalContentAlignment="Center"
				Width="50"
				Height="20"
				Content="{Binding Value, Converter='{x:Static ViewModel:ConverterProvider.FaderValueToStringConverter}'}" />
			<JCustomControls:JSwitcher
				Foreground="#FFFFFFFF"
				Style="{StaticResource Switcher_Normal}"
				Height="20"
				Width="50"
				Margin="0,2,0,0"
				Content="{Binding IsFrontSet, Converter='{x:Static ViewModel:ConverterProvider.BoolToResourceStringConverter}', ConverterParameter=Str_PrePost}"
				IsChecked="{Binding IsFrontSet}"
				Command="{Binding Command}"
				CommandParameter="{Binding ChannelIndex}" />
		</StackPanel>
	</Border>
</UserControl>
