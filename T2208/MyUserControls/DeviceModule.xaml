<UserControl
	x:Class="T2208.MyUserControls.DeviceModule"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:T2208.MyUserControls"
	Foreground="#FFFFFFFF">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<Style
				x:Key="{x:Type TextBlock}"
				TargetType="{x:Type TextBlock}">
				<Setter
					Property="TextBlock.TextAlignment"
					Value="Center" />
				<Setter
					Property="VerticalAlignment"
					Value="Center" />
			</Style>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Border
		Name="BD"
		CornerRadius="10"
		Background="#ff3c3c3c"
		BorderThickness="3"
		BorderBrush="#FFFF0000">
		<StackPanel
			Orientation="Horizontal"
			Margin="10">
			<UniformGrid
				Columns="1">
				<TextBlock
					Text="{DynamicResource Str_Name}" />
				<TextBlock
					Text="{DynamicResource Str_Addr}" />
				<TextBlock
					Text="{DynamicResource Str_MAC}" />
			</UniformGrid>
			<UniformGrid
				Columns="1">
				<TextBlock
					Text="{Binding Path=DeviceName, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:DeviceModule}}" />
				<TextBlock
					Text="{Binding Path=Address, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:DeviceModule}}" />
				<TextBlock
					Text="{Binding Path=MAC, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:DeviceModule}}" />
			</UniformGrid>
		</StackPanel>
	</Border>
</UserControl>
