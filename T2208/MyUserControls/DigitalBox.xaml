<UserControl
	x:Class="T2208.MyUserControls.DigitalBox"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:T2208.MyUserControls"
	xmlns:JCustomControl="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib"
	xmlns:ViewModels="clr-namespace:T2208.ViewModels">
	<Border
		Background="#00FFFFFF">
		<FrameworkElement.Style>
			<Style
				TargetType="{x:Type Border}">
				<Setter
					Property="BorderThickness"
					Value="2" />
				<Setter
					Property="BorderBrush"
					Value="#00FFFFFF" />
				<Style.Triggers>
					<Trigger
						Property="UIElement.IsMouseOver"
						Value="True">
						<Setter
							Property="BorderBrush"
							Value="#FF00FF00" />
					</Trigger>
				</Style.Triggers>
			</Style>
		</FrameworkElement.Style>
		<StackPanel
			Margin="1">
			<UniformGrid
				Columns="1">
				<JCustomControl:JSpinner
					Foreground="#FFFFFFFF"
					Margin="2"
					IsUIFireEventDirectly="True"
					BorderThickness="0"
					ItemsSource="{x:Static ViewModels:Const.FaderStrings}"
					Value="{Binding Value}"
					SendValue="{Binding SendValue, Mode=TwoWay}"
					CommonCommand="{Binding CommonCommand}" />
				<JCustomControl:JSwitcher
					Margin="2"
					Style="{StaticResource Switcher_Normal}"
					IsChecked="{Binding IsFrontSet}"
					Command="{Binding CommonCommand}"
					Content="{Binding IsFrontSet, Converter='{x:Static ViewModels:ConverterProvider.BoolToStringConverter}', ConverterParameter=On|Off}" />
			</UniformGrid>
			<TextBlock
				Foreground="#FFFFFFFF"
				TextAlignment="Center"
				Text="{Binding ChannelName}" />
		</StackPanel>
	</Border>
</UserControl>
