<UserControl
	x:Class="T2208.MyUserControls.ChannelFader"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:T2208.MyUserControls"
	xmlns:JCustomControls="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib"
	xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
	xmlns:ViewModels="clr-namespace:T2208.ViewModels"
	FontSize="10"
	ToolTip="{Binding DefaultChannelName}">
	<Grid>
		<i:Interaction.Triggers>
			<i:EventTrigger
				EventName="MouseEnter">
				<i:InvokeCommandAction
					Command="{Binding MouseEnterCommand}" />
			</i:EventTrigger>
		</i:Interaction.Triggers>
		<Grid.RowDefinitions>
			<RowDefinition
				Height="23" />
			<RowDefinition
				Height="23" />
			<RowDefinition
				Height="23" />
			<RowDefinition />
			<RowDefinition
				Height="25" />
		</Grid.RowDefinitions>
		<JCustomControls:JSwitcher
			Name="text"
			Grid.Row="0"
			Margin="8,2"
			Style="{StaticResource Switcher_Channel}"
			Content="{Binding ChannelName}"
			IsChecked="{Binding IsPresentChannel, Mode=TwoWay}"
			Command="{Binding UpdatePresentChannelCommand}">
			<UIElement.InputBindings>
				<MouseBinding
					MouseAction="LeftDoubleClick"
					Command="{Binding EditChannelNameCommand}"
					CommandParameter="{Binding ElementName=TB}" />
			</UIElement.InputBindings>
		</JCustomControls:JSwitcher>
		<TextBox
			Name="TB"
			Grid.Row="0"
			Margin="8,2"
			Style="{StaticResource T2208.TextBox.Style}"
			MaxLength="8"
			InputMethod.IsInputMethodEnabled="False"
			Text="{Binding InputName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
			IsHitTestVisible="{Binding IsEditName}"
			Visibility="{Binding IsEditName, Converter='{x:Static ViewModels:ConverterProvider.BoolToVisibilityConverter}'}"
			LostFocus="LostFocusEvents">
			<UIElement.InputBindings>
				<KeyBinding
					Key="Return"
					Command="{Binding SetChannenlNameCommand}" />
			</UIElement.InputBindings>
		</TextBox>
		<JCustomControls:JSwitcher
			Grid.Row="1"
			Margin="8,2"
			Content="{DynamicResource Str_Mute}"
			Style="{StaticResource Switcher_Mute}"
			IsChecked="{Binding IsMute}"
			Command="{Binding MuteGainChangeCommand}" />
		<JCustomControls:JSwitcher
			Grid.Row="2"
			Margin="8,2"
			Content="{DynamicResource Str_Solo}"
			Style="{StaticResource Switcher_Solo}"
			IsChecked="{Binding IsSolo}"
			IsEnabled="{Binding IsMain, Converter='{x:Static ViewModels:ConverterProvider.BoolOppositeConverter}'}"
			Command="{Binding SoloCommand}" />
		<Label
			Height="25"
			Grid.Row="4"
			Margin="0,0"
			DockPanel.Dock="Bottom"
			HorizontalContentAlignment="Center"
			HorizontalAlignment="Stretch"
			Content="{Binding GainValue, Converter='{x:Static ViewModels:ConverterProvider.FaderValueToStringConverter}'}" />
		<DockPanel
			Grid.Row="3"
			Margin="8,0">
			<JCustomControls:JMeter
				Name="Meter"
				Foreground="#FFFFFFFF"
				DockPanel.Dock="Right"
				HorizontalAlignment="Right"
				TextCollection="{x:Static ViewModels:Const.MeterStrings}"
				IsDockRight="False"
				FontSize="8"
				Value="{Binding MeterValue}"
				IsMainMeter="{Binding IsMain}" />
			<JCustomControls:JSlider
				Foreground="#FFFFFFFF"
				Style="{StaticResource Slider_Vertical}"
				IsUIFireEventDirectly="True"
				ThumbImageWidth="15"
				Maximum="{x:Static ViewModels:Const.FaderValueMaximum}"
				TickTexts="{x:Static ViewModels:Const.FaderTickStrings}"
				TickPlacement="TopLeft"
				FontSize="8"
				Value="{Binding GainValue}"
				SendValue="{Binding SendGainValue, Mode=TwoWay}"
				SendValueChanged="JSlider_SlideValueChangedEvent"
				GotFocus="SelectedEvents">
				<i:Interaction.Triggers>
					<i:EventTrigger
						EventName="SendValueChanged">
						<i:InvokeCommandAction
							Command="{Binding MuteGainChangeCommand}" />
					</i:EventTrigger>
				</i:Interaction.Triggers>
			</JCustomControls:JSlider>
		</DockPanel>
	</Grid>
</UserControl>
