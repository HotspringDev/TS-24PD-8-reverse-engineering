<Window
	x:Class="T2208.InputWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:viewModel="clr-namespace:T2208.ViewModels"
	xmlns:local="clr-namespace:T2208"
	Height="120"
	Width="230"
	ResizeMode="NoResize"
	WindowStartupLocation="CenterOwner"
	WindowStyle="ToolWindow"
	Title="{Binding Title}">
	<DockPanel
		Background="#FF000000"
		HorizontalAlignment="Stretch"
		VerticalAlignment="Stretch">
		<StackPanel
			DockPanel.Dock="Bottom"
			HorizontalAlignment="Right"
			Orientation="Horizontal">
			<Button
				Content="{DynamicResource Str_Confirm}"
				Width="80"
				Height="30"
				Margin="3"
				Command="{Binding ConfirmCommand}" />
			<Button
				Content="{DynamicResource Str_Cancel}"
				Width="80"
				Height="30"
				Margin="3"
				Command="{Binding CancelCommand}" />
		</StackPanel>
		<TextBox
			Name="InputStrings"
			Margin="5"
			Width="200"
			Height="40"
			MaxLength="16"
			TextAlignment="Left"
			Foreground="#FFFFFFFF"
			Text="{Binding InputString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
	</DockPanel>
</Window>
