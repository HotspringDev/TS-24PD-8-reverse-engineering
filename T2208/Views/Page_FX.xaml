<Page
	x:Class="T2208.Views.Page_FX"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:om="clr-namespace:Lib.Controls.FFTControl;assembly=Lib.Controls.MyControls"
	xmlns:JCustomControls="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib"
	xmlns:ViewModels="clr-namespace:T2208.ViewModels"
	xmlns:Infos="clr-namespace:T2208.MyInformations"
	xmlns:local="clr-namespace:T2208.Views"
	xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
	xmlns:MyUserControls="clr-namespace:T2208.MyUserControls"
	Title="Page_FX">
	<StackPanel
		Background="{StaticResource Image_Background}">
		<i:Interaction.Triggers>
			<i:EventTrigger
				EventName="Loaded">
				<i:InvokeCommandAction
					Command="{Binding PageLoadCommand}" />
			</i:EventTrigger>
		</i:Interaction.Triggers>
		<DockPanel>
			<Border
				DockPanel.Dock="Top">
				<DockPanel>
					<JCustomControls:TabPanelListBox
						DockPanel.Dock="Top"
						HorizontalAlignment="Center"
						Width="200"
						Height="40"
						Style="{StaticResource TabPanelUniformGrid}"
						ItemsSource="{Binding FXGroups}"
						SelectedItem="{Binding SelectedFX, Mode=TwoWay}"
						SelectedIndex="{Binding SelectedFXIndex, Mode=TwoWay}">
						<i:Interaction.Triggers>
							<i:EventTrigger
								EventName="SelectionChanged">
								<i:InvokeCommandAction
									Command="{Binding FXChangeCommand}" />
							</i:EventTrigger>
						</i:Interaction.Triggers>
						<ItemsControl.ItemContainerStyle>
							<Style
								BasedOn="{StaticResource TabPanelItemButton}"
								TargetType="{x:Type JCustomControls:TabPanelListBoxItem}">
								<Setter
									Property="Margin"
									Value="5" />
								<Setter
									Property="VerticalContentAlignment"
									Value="Center" />
								<Setter
									Property="Foreground"
									Value="#FFD3D3D3" />
								<Setter
									Property="HorizontalContentAlignment"
									Value="Center" />
							</Style>
						</ItemsControl.ItemContainerStyle>
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Grid>
									<TextBlock
										VerticalAlignment="Center"
										TextAlignment="Center"
										Text="{Binding GroupName}"
										Style="{x:Null}" />
								</Grid>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</JCustomControls:TabPanelListBox>
					<Border
						DockPanel.Dock="Top"
						Margin="5"
						BorderBrush="#FFFFFFFF"
						BorderThickness="0,0,0,2">
						<TextBlock
							Foreground="#FFFFFFFF"
							Margin="5"
							TextAlignment="Center"
							FontSize="20"
							Text="{DynamicResource Str_EffectType}" />
					</Border>
					<JCustomControls:TabPanelListBox
						Style="{StaticResource TabPanelFX}"
						Width="600"
						Height="100"
						DockPanel.Dock="Top"
						ItemsSource="{Binding SelectedFX.GroupCollection}"
						SelectedItem="{Binding SelectedEffectGroup, Mode=TwoWay}"
						SelectedIndex="{Binding SelectedEffectIndex, Mode=TwoWay}">
						<i:Interaction.Triggers>
							<i:EventTrigger
								EventName="SelectionChanged">
								<i:InvokeCommandAction
									Command="{Binding EffectChangeCommand}" />
							</i:EventTrigger>
						</i:Interaction.Triggers>
						<ItemsControl.ItemContainerStyle>
							<Style
								BasedOn="{StaticResource TabPanelItemButton}"
								TargetType="{x:Type JCustomControls:TabPanelListBoxItem}">
								<Setter
									Property="ListBoxItem.IsSelected"
									Value="{Binding IsSelected}" />
								<Setter
									Property="Margin"
									Value="5" />
								<Setter
									Property="VerticalContentAlignment"
									Value="Center" />
								<Setter
									Property="HorizontalContentAlignment"
									Value="Center" />
							</Style>
						</ItemsControl.ItemContainerStyle>
						<ItemsControl.ItemTemplate>
							<DataTemplate
								DataType="{x:Type Infos:FXItem}">
								<JCustomControls:JSwitcher
									Height="29"
									Width="80"
									Content="{Binding Name}"
									IsChecked="{Binding IsSelected}" />
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</JCustomControls:TabPanelListBox>
					<Border
						DockPanel.Dock="Top"
						Margin="5"
						BorderBrush="#FFFFFFFF"
						BorderThickness="0,0,0,2">
						<TextBlock
							Foreground="#FFFFFFFF"
							Margin="5"
							TextAlignment="Center"
							FontSize="20" />
					</Border>
					<JCustomControls:ListDisplayer
						Width="800"
						DockPanel.Dock="Top"
						Foreground="#FFFFFFFF"
						ItemsSource="{Binding Effects}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel
									HorizontalAlignment="Center" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate
								DataType="{x:Type Infos:EffectInfo}">
								<StackPanel
									Margin="10,5"
									Width="110"
									Visibility="{Binding IsEnabled, Converter='{x:Static ViewModels:ConverterProvider.BoolToVisibilityConverter}', ConverterParameter=Collapsed}">
									<TextBlock
										VerticalAlignment="Center"
										TextAlignment="Center"
										Margin="5"
										Text="{Binding Name}"
										Style="{x:Null}" />
									<JCustomControls:JSpinner
										IsUIFireEventDirectly="True"
										SpinnerType="ItemSource"
										Height="25"
										CommonCommand="{Binding CommonCommand}"
										ItemsSource="{Binding EffectValueCollection}"
										SendValue="{Binding EffectSendValue, Mode=TwoWay}"
										Value="{Binding EffectValue}" />
								</StackPanel>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</JCustomControls:ListDisplayer>
				</DockPanel>
			</Border>
		</DockPanel>
	</StackPanel>
</Page>
