<Page
	x:Class="T2208.Views.Page_SaveLoadCopy"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:om="clr-namespace:Lib.Controls.FFTControl;assembly=Lib.Controls.MyControls"
	xmlns:JCustomControls="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib"
	xmlns:ViewModels="clr-namespace:T2208.ViewModels"
	xmlns:Infos="clr-namespace:T2208.MyInformations"
	xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
	xmlns:local="clr-namespace:T2208.Views"
	xmlns:MyUserControls="clr-namespace:T2208.MyUserControls"
	Title="Page_SaveLoadCopy">
	<DockPanel>
		<Border
			Width="600"
			BorderThickness="1"
			BorderBrush="{StaticResource Brush_Stereoscopic}"
			Background="{StaticResource Image_Background}"
			Margin="5">
			<i:Interaction.Triggers>
				<i:EventTrigger
					EventName="MouseEnter">
					<i:InvokeCommandAction
						Command="{Binding MouseEnterSaveLoadAreaCommand}" />
				</i:EventTrigger>
			</i:Interaction.Triggers>
			<DockPanel>
				<Border
					DockPanel.Dock="Top"
					Margin="5,2"
					BorderBrush="#FFFFFFFF"
					BorderThickness="0,0,0,2">
					<TextBlock
						Foreground="#FFFFFFFF"
						Text="{DynamicResource Str_SaveLoad}" />
				</Border>
				<TextBlock
					DockPanel.Dock="Top" />
				<ListView
					DockPanel.Dock="Top"
					Height="210"
					Width="560"
					HorizontalAlignment="Center"
					Foreground="#FFFFFFFF"
					FontFamily="Verdana"
					Background="#FF000000"
					Margin="20,5"
					BorderBrush="#FFFFFF00"
					BorderThickness="2"
					ItemsSource="{Binding SelectGroup.PresetItems}"
					SelectedIndex="{Binding SelectGroup.SelectedPresetIndex, Mode=TwoWay}">
					<ItemsControl.ItemTemplate>
						<DataTemplate
							DataType="{x:Type ViewModels:PresetItem}">
							<Border
								Margin="3"
								BorderBrush="#FFFFFF00"
								BorderThickness="0,0,0,1"
								HorizontalAlignment="Stretch"
								Width="525">
								<DockPanel>
									<TextBlock
										DockPanel.Dock="Left"
										Margin="5,0"
										Text="{Binding Group}" />
									<TextBlock
										DockPanel.Dock="Left"
										Margin="8,0"
										Text="{Binding IndexString}" />
									<TextBlock
										DockPanel.Dock="Left"
										TextAlignment="Left"
										Margin="8,0,0,0"
										Text="{Binding PresetName}" />
								</DockPanel>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ListView>
				<JCustomControls:TabPanelListBox
					DockPanel.Dock="Top"
					Width="560"
					Height="50"
					Margin="20,5"
					Style="{StaticResource TabPanelUniformGrid}"
					ItemsSource="{Binding SelectedPresetGroups}"
					SelectedItem="{Binding SelectGroup, Mode=TwoWay}"
					SelectedIndex="{Binding SelectedGroupIndex, Mode=TwoWay}">
					<ItemsControl.ItemContainerStyle>
						<Style
							BasedOn="{StaticResource TabPanelItemButton}"
							TargetType="{x:Type JCustomControls:TabPanelListBoxItem}">
							<Setter
								Property="Margin"
								Value="5" />
							<Setter
								Property="VerticalContentAlignment"
								Value="Center" />
							<Setter
								Property="HorizontalContentAlignment"
								Value="Center" />
						</Style>
					</ItemsControl.ItemContainerStyle>
					<ItemsControl.ItemTemplate>
						<DataTemplate
							DataType="{x:Type ViewModels:PresetGroup}">
							<TextBlock
								VerticalAlignment="Center"
								TextAlignment="Center"
								Foreground="#FFFFFFFF"
								Text="{Binding GroupName}"
								Style="{x:Null}" />
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</JCustomControls:TabPanelListBox>
				<StackPanel
					Orientation="Horizontal"
					DockPanel.Dock="Top"
					HorizontalAlignment="Center">
					<TextBlock
						Foreground="#FFFFFFFF"
						Margin="3,0"
						Text="{DynamicResource Str_State}" />
					<Label
						Width="100"
						HorizontalContentAlignment="Center"
						Margin="3,0"
						Content="{Binding SelectGroup.GroupName}" />
					<Label
						Width="100"
						HorizontalContentAlignment="Center"
						Margin="3,0"
						Content="{Binding SelectGroup.SelectChannel}"
						Visibility="{Binding SelectGroup.SelectChannel, Converter='{x:Static ViewModels:ConverterProvider.NullToVisibilityConverter}'}" />
					<Label
						Width="100"
						HorizontalContentAlignment="Center"
						Margin="3,0"
						Content="{Binding SelectGroup.SelectedPreset}"
						Visibility="{Binding SelectGroup.SelectedPreset, Converter='{x:Static ViewModels:ConverterProvider.NullToVisibilityConverter}'}" />
				</StackPanel>
				<Border
					DockPanel.Dock="Top"
					BorderBrush="#FFD3D3D3"
					BorderThickness="2"
					Padding="2"
					Margin="20,5">
					<DockPanel>
						<RadioButton
							Name="DevicePresetBtn"
							DockPanel.Dock="Left"
							Foreground="#FFFFFFFF"
							Margin="5,0"
							GroupName="Presets"
							CommandParameter="{StaticResource INT_0}"
							Command="{Binding SwitchButtonGroupCommand}" />
						<RadioButton
							DockPanel.Dock="Left"
							Foreground="#FFFFFFFF"
							Margin="5,0"
							GroupName="Presets"
							CommandParameter="{StaticResource INT_1}"
							IsChecked="True"
							Command="{Binding SwitchButtonGroupCommand}">PC</RadioButton>
						<JCustomControls:ListDisplayer
							ItemsSource="{Binding ButtonGroup}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<UniformGrid
										Rows="1" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate
									DataType="{x:Type ViewModels:ButtonItem}">
									<Button
										Width="80"
										Margin="5,0"
										Content="{Binding NotificationContent}"
										Command="{Binding Command}" />
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</JCustomControls:ListDisplayer>
					</DockPanel>
				</Border>
				<Border />
			</DockPanel>
		</Border>
		<Border
			BorderThickness="1"
			BorderBrush="{StaticResource Brush_Stereoscopic}"
			Background="{StaticResource Image_Background}"
			Margin="5">
			<i:Interaction.Triggers>
				<i:EventTrigger
					EventName="MouseEnter">
					<i:InvokeCommandAction
						Command="{Binding MouseEnterCopyAreaCommand}" />
				</i:EventTrigger>
			</i:Interaction.Triggers>
			<DockPanel>
				<Border
					DockPanel.Dock="Top"
					Margin="5,2"
					BorderBrush="#FFFFFFFF"
					BorderThickness="0,0,0,2">
					<TextBlock
						Foreground="#FFFFFFFF"
						Text="{DynamicResource Str_Copy}" />
				</Border>
				<StackPanel
					Orientation="Horizontal"
					DockPanel.Dock="Top"
					Margin="20">
					<TextBlock />
					<ComboBox
						Width="70"
						ItemsSource="{Binding ChannelGroup}"
						SelectedIndex="{Binding SelectedCopyChannelIndex}" />
					<TextBlock />
				</StackPanel>
				<StackPanel
					Orientation="Horizontal"
					DockPanel.Dock="Bottom"
					HorizontalAlignment="Center"
					Margin="5">
					<JCustomControls:JSwitcher
						Margin="5"
						Width="60"
						Height="30"
						Content="{DynamicResource Str_SelectAll}"
						Command="{Binding SelectAllCommand}"
						IsChecked="{Binding IsClickAll}" />
					<Button
						Margin="5"
						Width="60"
						Height="30"
						Content="{DynamicResource Str_Copy}"
						Command="{Binding CopyCommand}" />
				</StackPanel>
				<JCustomControls:ListDisplayer
					HorizontalAlignment="Center"
					DockPanel.Dock="Bottom"
					ItemsSource="{Binding CopyItemGroup}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<UniformGrid
								Rows="2"
								HorizontalAlignment="Center" />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate
							DataType="{x:Type ViewModels:CheckBoxItem}">
							<CheckBox
								Foreground="#FFFFFFFF"
								Margin="3"
								Width="85"
								Content="{Binding Content}"
								IsChecked="{Binding IsChecked, Mode=TwoWay}"
								Command="{Binding Command}"
								IsEnabled="{Binding IsEnabled}" />
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</JCustomControls:ListDisplayer>
				<JCustomControls:ListDisplayer
					HorizontalAlignment="Center"
					ItemsSource="{Binding CheckBoxGroup}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate
							DataType="{x:Type ViewModels:CheckBoxItem}">
							<CheckBox
								Foreground="#FFFFFFFF"
								Margin="3"
								Width="70"
								Content="{Binding Content}"
								IsChecked="{Binding IsChecked, Mode=TwoWay}"
								Command="{Binding Command}"
								IsEnabled="{Binding IsEnabled}" />
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</JCustomControls:ListDisplayer>
			</DockPanel>
		</Border>
	</DockPanel>
</Page>
