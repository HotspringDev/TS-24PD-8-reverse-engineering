<Page
	x:Class="T2208.Views.AssignChannel"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:oc="clr-namespace:Lib.Controls;assembly=Lib.Controls.MyControls"
	xmlns:fft="clr-namespace:FFT;assembly=FFT"
	xmlns:Infos="clr-namespace:T2208.MyInformations"
	xmlns:JCustomControls="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib"
	xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
	xmlns:ViewModels="clr-namespace:T2208.ViewModels"
	xmlns:sys="clr-namespace:System;assembly=mscorlib"
	xmlns:local="clr-namespace:T2208.Views"
	Foreground="#FFFFFFFF"
	Title="AssignChannel"
	DataContext="{Binding Source='{x:Static ViewModels:ViewModelLocator.DSP}'}"
	Loaded="Page_Loaded">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<sys:String
				x:Key="InvertStrings">180°|0°</sys:String>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Grid
		DataContext="{Binding ChannelInfo}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition />
			<ColumnDefinition
				Width="3.1*" />
			<ColumnDefinition
				Width="1.2*" />
		</Grid.ColumnDefinitions>
		<Border
			x:Name="gateBorder"
			Background="{DynamicResource Image_Background}"
			BorderThickness="1"
			BorderBrush="#00FFFFFF"
			Padding="5">
			<Viewbox>
				<Grid
					ClipToBounds="True">
					<Grid.RowDefinitions>
						<RowDefinition
							Height="auto" />
						<RowDefinition
							Height="auto" />
						<RowDefinition
							Height="auto" />
						<RowDefinition
							Height="auto" />
					</Grid.RowDefinitions>
					<Grid
						x:Name="gategrid2"
						IsEnabled="{Binding HasNoiseGate}">
						<i:Interaction.Triggers>
							<i:EventTrigger
								EventName="MouseEnter">
								<i:InvokeCommandAction
									CommandParameter="{StaticResource INT_0}"
									Command="{Binding MouseEnterOtherWithParameterCommand}" />
							</i:EventTrigger>
						</i:Interaction.Triggers>
						<Grid.RowDefinitions>
							<RowDefinition
								Height="20" />
							<RowDefinition
								Height="1.8*" />
							<RowDefinition
								Height="auto" />
							<RowDefinition
								Height="auto" />
						</Grid.RowDefinitions>
						<DockPanel
							x:Name="gateleftdockpanel">
							<TextBlock
								Margin="5,0,0,0"
								VerticalAlignment="Center"
								Text="{DynamicResource Str_NoiseGate}"
								DockPanel.Dock="Left" />
							<Control
								Style="{StaticResource Control_Led}"
								Height="14"
								Width="14"
								Margin="3"
								DockPanel.Dock="Right"
								Background="{Binding NoiseGateInfo.Active, Converter='{x:Static ViewModels:ConverterProvider.ByteToBrushConverter}'}" />
							<TextBlock
								Margin="0,0,5,0"
								Text="{DynamicResource Str_NoiseGateLight}"
								DockPanel.Dock="Right"
								HorizontalAlignment="Right"
								VerticalAlignment="Center" />
						</DockPanel>
						<JCustomControls:JLimitGDSlider
							CanvasBrush="#5E5F5D"
							Grid.Row="1"
							Ratio="0"
							MaxThreshold="20"
							MinThreshold="-84"
							Width="165"
							Height="145"
							FontSize="10"
							Foreground="#FFFFFFFF"
							AxisTexts="{x:Static ViewModels:Const.NoiseGateCoordinateAxis}"
							Threshold="{Binding NoiseGateInfo.ThresholdValue}" />
						<UniformGrid
							Margin="0 1"
							Rows="2"
							Grid.Row="2"
							IsEnabled="{Binding NoiseGateInfo.NoiseGateEnable}">
							<i:Interaction.Triggers>
								<i:EventTrigger
									EventName="MouseEnter">
									<i:InvokeCommandAction
										CommandParameter="{StaticResource INT_0}"
										Command="{Binding MouseEnterOtherWithParameterCommand}" />
								</i:EventTrigger>
							</i:Interaction.Triggers>
							<StackPanel>
								<TextBlock
									VerticalAlignment="Center"
									Margin="2"
									Text="{DynamicResource Str_Threshold}"
									FontSize="11"
									Foreground="#FFFFFFFF" />
								<JCustomControls:JSpinner
									CanEdit="True"
									ItemsSource="{x:Static ViewModels:Const.NoiseGateThresholds}"
									Height="20"
									CalculateValueFunction="{Binding NGThresFunc}"
									CommonCommand="{Binding NoiseGateBypassCommand}"
									Value="{Binding NoiseGateInfo.Threshold}" />
							</StackPanel>
							<StackPanel>
								<TextBlock
									x:Name="RATIO"
									VerticalAlignment="Center"
									Margin="2"
									Foreground="#FFFFFFFF"
									FontSize="11"
									Text="{DynamicResource Str_NoiseGateRatio}" />
								<JCustomControls:JSpinner
									CanEdit="False"
									Text="Limit"
									IsEnabled="False"
									Height="20"
									CalculateValueFunction="{Binding NGRatioFunc}"
									CommonCommand="{Binding NoiseGateBypassCommand}" />
							</StackPanel>
							<StackPanel>
								<TextBlock
									VerticalAlignment="Center"
									Margin="2"
									Text="{DynamicResource Str_Attack}"
									FontSize="11"
									Foreground="#FFFFFFFF" />
								<JCustomControls:JSpinner
									CanEdit="True"
									ItemsSource="{x:Static ViewModels:Const.NoiseGateAttacks}"
									Height="20"
									CalculateValueFunction="{Binding NGATKFunc}"
									CommonCommand="{Binding NoiseGateBypassCommand}"
									Value="{Binding NoiseGateInfo.Attack}" />
							</StackPanel>
							<StackPanel>
								<TextBlock
									VerticalAlignment="Center"
									Margin="2"
									Text="{DynamicResource Str_Release}"
									FontSize="11"
									Foreground="#FFFFFFFF" />
								<JCustomControls:JSpinner
									CanEdit="True"
									ItemsSource="{x:Static ViewModels:Const.NoiseGateReleases}"
									Height="20"
									CalculateValueFunction="{Binding NGReleaseFunc}"
									CommonCommand="{Binding NoiseGateBypassCommand}"
									Value="{Binding NoiseGateInfo.Release}" />
							</StackPanel>
						</UniformGrid>
						<JCustomControls:JSwitcher
							Margin="0 3 0 0"
							Grid.Row="3"
							Style="{StaticResource Switcher_Red}"
							VerticalAlignment="Center"
							Height="20"
							Width="80"
							Content="{DynamicResource Str_Bypass}"
							Command="{Binding NoiseGateBypassCommand}"
							IsChecked="{Binding NoiseGateInfo.NoiseGateEnable, Converter='{x:Static ViewModels:ConverterProvider.BoolOppositeConverter}'}" />
					</Grid>
					<DockPanel
						Margin="0,0,8,0"
						Height="20"
						Grid.Row="1">
						<i:Interaction.Triggers>
							<i:EventTrigger
								EventName="MouseEnter">
								<i:InvokeCommandAction
									Command="{Binding MouseEnterOtherCommand}" />
							</i:EventTrigger>
						</i:Interaction.Triggers>
						<TextBlock
							DockPanel.Dock="Left"
							Padding="0"
							Foreground="#FFFFFFFF"
							Text="Pan" />
						<Label
							Margin="2,0,0,0"
							Width="30"
							HorizontalContentAlignment="Center"
							DockPanel.Dock="Right"
							Height="20"
							Visibility="Collapsed"
							Content="{Binding PanValue}" />
						<Grid>
							<JCustomControls:LedSlider
								Cursor="Hand"
								Mar="2"
								Effect="{DynamicResource Effect_Normal}"
								Tag="1"
								MaxLedNum="24"
								LedNum="{Binding PanValue}"
								SliderValueChanged="LedSlider_SliderValueChanged">
								<i:Interaction.Triggers>
									<i:EventTrigger
										EventName="MouseMove">
										<i:InvokeCommandAction
											Command="{Binding PanValueChangeCommand}" />
									</i:EventTrigger>
									<i:EventTrigger
										EventName="MouseDown">
										<i:InvokeCommandAction
											Command="{Binding PanValueChangeCommand}" />
									</i:EventTrigger>
								</i:Interaction.Triggers>
							</JCustomControls:LedSlider>
							<Border
								IsHitTestVisible="False"
								Background="{StaticResource Brush_Stereoscopic}" />
						</Grid>
					</DockPanel>
					<DockPanel
						Height="25"
						Margin="6,1"
						Grid.Row="2">
						<i:Interaction.Triggers>
							<i:EventTrigger
								EventName="MouseEnter">
								<i:InvokeCommandAction
									Command="{Binding MouseEnterOtherCommand}" />
							</i:EventTrigger>
						</i:Interaction.Triggers>
						<JCustomControls:JSwitcher
							DockPanel.Dock="Left"
							Width="50"
							Content="DC 48V"
							IsChecked="{Binding DC48VEnabled}"
							IsEnabled="{Binding HasDC48V}"
							Command="{Binding DC48Command}" />
						<Label
							DockPanel.Dock="Right"
							Margin="0"
							Foreground="#FFFF0000"
							VerticalContentAlignment="Center"
							HorizontalContentAlignment="Left"
							Width="35"
							Content="{Binding Invert, Converter='{x:Static ViewModels:ConverterProvider.BoolToStringConverter}', ConverterParameter=180°|0°}" />
						<JCustomControls:JSwitcher
							DockPanel.Dock="Right"
							Margin="0 0 10 0"
							Width="45"
							Content="{DynamicResource Str_Invert}"
							IsChecked="{Binding Invert}"
							Command="{Binding InvertCommand}" />
						<Control
							Style="{StaticResource Control_Led}"
							Width="3"
							Margin="1"
							Background="#FFFFFFFF"
							HorizontalAlignment="Center" />
					</DockPanel>
					<DockPanel
						Grid.Row="3"
						Margin="0 5 0 0">
						<i:Interaction.Triggers>
							<i:EventTrigger
								EventName="MouseEnter">
								<i:InvokeCommandAction
									Command="{Binding MouseEnterOtherCommand}" />
							</i:EventTrigger>
						</i:Interaction.Triggers>
						<DockPanel
							Dock="Top">
							<TextBlock
								Text="{DynamicResource Str_Delay}"
								Foreground="#FFFFFFFF"
								Padding="0"
								DockPanel.Dock="Left" />
							<Control
								Style="{StaticResource Control_Led}"
								Width="18"
								DockPanel.Dock="Right"
								Background="{Binding DelayEnabled, Converter='{x:Static ViewModels:ConverterProvider.BoolToBrushConverter}', ConverterParameter=LimeGreen|Red}" />
							<JCustomControls:JSwitcher
								Width="30"
								Margin="5,0"
								HorizontalAlignment="Right"
								Command="{Binding FatChannelCommand}"
								Content="{Binding DelayEnabled, Converter='{x:Static ViewModels:ConverterProvider.BoolToResourceStringConverter}', ConverterParameter=Str_OnOff}"
								IsChecked="{Binding DelayEnabled}" />
						</DockPanel>
						<DockPanel
							Grid.Row="1"
							Margin="-7,0,0,0"
							Dock="Top"
							IsEnabled="{Binding DelayEnabled}">
							<JCustomControls:JSpinner
								x:Name="delaymsStr"
								ItemsSource="{x:Static ViewModels:Const.DelayStrings}"
								CanEdit="True"
								Width="84"
								Height="22"
								CalculateValueFunction="{Binding DelayFunc}"
								CommonCommand="{Binding DelayValueChangeCommand}"
								Value="{Binding DelayValue, Mode=TwoWay}"
								SendValue="{Binding SendDelayValue, Mode=TwoWay}" />
							<TextBlock
								Text="(ms)"
								Foreground="#FFFFFFFF"
								Padding="0,0,5,0"
								VerticalAlignment="Center"
								Width="27" />
							<Label
								HorizontalContentAlignment="Center"
								Width="47"
								VerticalContentAlignment="Center"
								IsHitTestVisible="False"
								Height="22"
								Content="{Binding DelayValue, Converter='{x:Static ViewModels:ConverterProvider.DelayToStringConverter}'}" />
							<TextBlock
								Text="(M)"
								Foreground="#FFFFFFFF"
								VerticalAlignment="Center"
								Width="22" />
						</DockPanel>
						<JCustomControls:JSlider
							IsUIFireEventDirectly="True"
							Grid.Row="2"
							ThumbImage="{StaticResource Image_SliderThumb}"
							Maximum="1443"
							IsExteriorEnable="True"
							ThumbImageHeight="11"
							ThumbImageWidth="22"
							VerticalAlignment="Center"
							IsEnabled="{Binding DelayEnabled}"
							Value="{Binding DelayValue, Mode=TwoWay}"
							SendValue="{Binding SendDelayValue, Mode=TwoWay}"
							SendValueChanged="JSlider_SendValueChanged" />
					</DockPanel>
				</Grid>
			</Viewbox>
		</Border>
		<Border
			Background="{DynamicResource Image_Background}"
			BorderThickness="1"
			BorderBrush="#00FFFFFF"
			Grid.Column="1"
			Grid.Row="0"
			Margin="5,0"
			Padding="5">
			<i:Interaction.Triggers>
				<i:EventTrigger
					EventName="MouseEnter">
					<i:InvokeCommandAction
						CommandParameter="{StaticResource INT_2}"
						Command="{Binding MouseEnterOtherWithParameterCommand}" />
				</i:EventTrigger>
			</i:Interaction.Triggers>
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition
						Height="1.3*" />
					<RowDefinition />
				</Grid.RowDefinitions>
				<Grid
					Row="0"
					IsEnabled="{Binding EqualizerAllBypass}">
					<Grid.RowDefinitions>
						<RowDefinition
							Height="auto" />
						<RowDefinition />
					</Grid.RowDefinitions>
					<TextBlock
						Foreground="#FFFFFFFF"
						HorizontalAlignment="Center"
						Text="{DynamicResource Str_EQ}" />
					<fft:FFT_BackText
						SnapsToDevicePixels="False"
						BackBrush="Transparent"
						GridHeaderBrush="Lime"
						GridBrush="LimeGreen"
						Grid.Row="1"
						Margin="25,5,8,10"
						TextBrush2="White" />
					<fft:FFTDrawer
						x:Name="fftfrawer"
						Grid.Row="1"
						IsSetEqBoxColor="True"
						Margin="25,5,8,10"
						isHasHLPF="True"
						gLineBrush="Red"
						CaptureRadius="10"
						BlockDiameter="11"
						gLineWidth="3"
						IsEnabled="{Binding EqualizerAllBypass}" />
				</Grid>
				<Viewbox
					Grid.Row="1"
					Stretch="Fill">
					<Grid
						Width="584">
						<Grid.ColumnDefinitions>
							<ColumnDefinition />
							<ColumnDefinition
								Width="3.8*" />
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition />
							<RowDefinition
								Height="auto" />
						</Grid.RowDefinitions>
						<Grid
							IsEnabled="{Binding EqualizerAllBypass}">
							<Grid.RowDefinitions>
								<RowDefinition />
								<RowDefinition />
							</Grid.RowDefinitions>
							<Grid
								Margin="2,0">
								<Grid.RowDefinitions>
									<RowDefinition
										Height="auto" />
									<RowDefinition />
									<RowDefinition />
								</Grid.RowDefinitions>
								<Grid.ColumnDefinitions>
									<ColumnDefinition />
									<ColumnDefinition
										Width="2*" />
								</Grid.ColumnDefinitions>
								<TextBlock
									VerticalAlignment="Bottom"
									Grid.ColumnSpan="2"
									Text="{DynamicResource Str_HighPassFilter}"
									HorizontalAlignment="Left"
									Foreground="#FFFFFFFF" />
								<TextBlock
									Grid.Row="1"
									Text="{DynamicResource Str_Freq}"
									Foreground="#FFFFFFFF"
									VerticalAlignment="Center" />
								<JCustomControls:JSpinner
									CommonCommandParameter="{StaticResource INT_0}"
									ItemsSource="{x:Static ViewModels:Const.Frequence128Strings}"
									Grid.Row="1"
									Grid.Column="1"
									Height="22"
									CanEdit="True"
									CalculateValueFunction="{Binding HPFFunc}"
									Value="{Binding HighPassFilter.FreqIndex}"
									CommonCommand="{Binding UpdateEqualizerCommand}" />
								<TextBlock
									Grid.Row="2"
									Text="{DynamicResource Str_Type}"
									Foreground="#FFFFFFFF"
									VerticalAlignment="Center" />
								<oc:TComboBox
									ItemsSource="{x:Static ViewModels:Const.High_LowPassFilter}"
									Grid.Row="2"
									Grid.Column="1"
									Height="22"
									SelectedIndex="{Binding HighPassFilter.FilterIndex}"
									DropDownOpened="TComboBox_DropDownOpened"
									DropDownClosed="TComboBox_DropDownClosed">
									<i:Interaction.Triggers>
										<i:EventTrigger
											EventName="SelectionChanged">
											<i:InvokeCommandAction
												CommandParameter="{StaticResource INT_0}"
												Command="{Binding UpdateEqualizerTypeCommand}" />
										</i:EventTrigger>
									</i:Interaction.Triggers>
								</oc:TComboBox>
							</Grid>
							<Grid
								Row="1"
								Margin="2,0">
								<Grid.RowDefinitions>
									<RowDefinition
										Height="auto" />
									<RowDefinition />
									<RowDefinition />
								</Grid.RowDefinitions>
								<Grid.ColumnDefinitions>
									<ColumnDefinition />
									<ColumnDefinition
										Width="2*" />
								</Grid.ColumnDefinitions>
								<TextBlock
									VerticalAlignment="Bottom"
									Grid.ColumnSpan="2"
									Text="{DynamicResource Str_LowPassFilter}"
									HorizontalAlignment="Left"
									Foreground="#FFFFFFFF" />
								<TextBlock
									Grid.Row="1"
									Text="{DynamicResource Str_Freq}"
									Foreground="#FFFFFFFF"
									VerticalAlignment="Center" />
								<JCustomControls:JSpinner
									CommonCommandParameter="{StaticResource INT_1}"
									ItemsSource="{x:Static ViewModels:Const.Frequence128Strings}"
									Tag="0"
									Grid.Row="1"
									Grid.Column="1"
									Height="22"
									CanEdit="True"
									CalculateValueFunction="{Binding LPFFunc}"
									Value="{Binding LowPassFilter.FreqIndex}"
									CommonCommand="{Binding UpdateEqualizerCommand}" />
								<TextBlock
									Grid.Row="2"
									Text="{DynamicResource Str_Type}"
									Foreground="#FFFFFFFF"
									VerticalAlignment="Center" />
								<oc:TComboBox
									ItemsSource="{x:Static ViewModels:Const.High_LowPassFilter}"
									Grid.Row="2"
									Grid.Column="1"
									Height="22"
									SelectedIndex="{Binding LowPassFilter.FilterIndex}"
									DropDownOpened="TComboBox_DropDownOpened"
									DropDownClosed="TComboBox_DropDownClosed">
									<i:Interaction.Triggers>
										<i:EventTrigger
											EventName="SelectionChanged">
											<i:InvokeCommandAction
												CommandParameter="{StaticResource INT_1}"
												Command="{Binding UpdateEqualizerTypeCommand}" />
										</i:EventTrigger>
									</i:Interaction.Triggers>
								</oc:TComboBox>
							</Grid>
						</Grid>
						<Grid
							x:Name="eqGrid"
							Column="1"
							IsEnabled="{Binding EqualizerAllBypass}">
							<Grid.RowDefinitions>
								<RowDefinition
									Height="24" />
								<RowDefinition
									Height="24" />
								<RowDefinition
									Height="24" />
								<RowDefinition
									Height="24" />
								<RowDefinition
									Height="24" />
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition
									Width="60" />
								<ColumnDefinition
									Width="45*" />
								<ColumnDefinition
									Width="45*" />
								<ColumnDefinition
									Width="45*" />
								<ColumnDefinition
									Width="37*" />
								<ColumnDefinition
									Width="58" />
							</Grid.ColumnDefinitions>
							<TextBlock
								Grid.Column="1"
								Text="{DynamicResource Str_Frequence}"
								Foreground="#FFFFFFFF"
								HorizontalAlignment="Center"
								Height="16"
								Margin="16,4"
								Width="58" />
							<TextBlock
								Grid.Column="2"
								Text="{DynamicResource Str_QFact}"
								Foreground="#FFFFFFFF"
								HorizontalAlignment="Center"
								Height="16"
								Margin="24,4,34,4"
								Width="32" />
							<TextBlock
								Grid.Column="3"
								Text="{DynamicResource Str_Gain}"
								Foreground="#FFFFFFFF"
								HorizontalAlignment="Center"
								Height="16"
								Margin="24,4,40,4"
								Width="26" />
							<TextBlock
								Grid.Column="4"
								Text="{DynamicResource Str_Type}"
								Foreground="#FFFFFFFF"
								HorizontalAlignment="Center"
								Height="16"
								Margin="14,4,32,4"
								Width="28" />
							<TextBlock
								Grid.Column="5"
								Text="{DynamicResource Str_Bypass}"
								Foreground="#FFFFFFFF"
								HorizontalAlignment="Center"
								Visibility="Hidden"
								Height="16"
								Margin="4,4,16,4"
								Width="38" />
							<StackPanel
								Margin="3,0,0,0"
								Grid.Row="1"
								Orientation="Horizontal">
								<TextBlock
									Width="36"
									Text="EQ1"
									Foreground="#FFFFFFFF" />
								<Control
									Style="{StaticResource Control_Led}"
									Width="18"
									Height="18"
									Background="#FFFAEBD7" />
							</StackPanel>
							<StackPanel
								Margin="3,0,0,0"
								Grid.Row="2"
								Orientation="Horizontal">
								<TextBlock
									Width="36"
									Text="EQ2"
									Foreground="#FFFFFFFF" />
								<Control
									Style="{StaticResource Control_Led}"
									Width="18"
									Height="18"
									Background="#FF6495ED" />
							</StackPanel>
							<StackPanel
								Margin="3,0,0,0"
								Grid.Row="3"
								Orientation="Horizontal">
								<TextBlock
									Width="36"
									Text="EQ3"
									Foreground="#FFFFFFFF" />
								<Control
									Style="{StaticResource Control_Led}"
									Width="18"
									Height="18"
									Background="#FF87CEEB" />
							</StackPanel>
							<StackPanel
								Margin="3,0,0,0"
								Grid.Row="4"
								Orientation="Horizontal">
								<TextBlock
									Width="36"
									Text="EQ4"
									Foreground="#FFFFFFFF" />
								<Control
									Style="{StaticResource Control_Led}"
									Width="18"
									Height="18"
									Background="#FFFF1493" />
							</StackPanel>
							<JCustomControls:JSpinner
								CommonCommandParameter="{StaticResource INT_2}"
								ItemsSource="{x:Static ViewModels:Const.Frequence128Strings}"
								HorizontalAlignment="Stretch"
								Grid.Column="1"
								Grid.Row="1"
								CanEdit="True"
								CalculateValueFunction="{Binding FreqFunc1}"
								IsEnabled="{Binding EqualizerEdit1.EqualizerEnable}"
								Value="{Binding EqualizerEdit1.FreqIndex, Mode=TwoWay}"
								SendValue="{Binding EqualizerEdit1.SendFreqIndex, Mode=TwoWay}"
								CommonCommand="{Binding UpdateEqualizerCommand}" />
							<JCustomControls:JSpinner
								CommonCommandParameter="{StaticResource INT_3}"
								ItemsSource="{x:Static ViewModels:Const.Frequence128Strings}"
								HorizontalAlignment="Stretch"
								Grid.Column="1"
								Grid.Row="2"
								CanEdit="True"
								CalculateValueFunction="{Binding FreqFunc2}"
								IsEnabled="{Binding EqualizerEdit2.EqualizerEnable}"
								Value="{Binding EqualizerEdit2.FreqIndex, Mode=TwoWay}"
								SendValue="{Binding EqualizerEdit2.SendFreqIndex, Mode=TwoWay}"
								CommonCommand="{Binding UpdateEqualizerCommand}" />
							<JCustomControls:JSpinner
								CommonCommandParameter="{StaticResource INT_4}"
								ItemsSource="{x:Static ViewModels:Const.Frequence128Strings}"
								HorizontalAlignment="Stretch"
								Grid.Column="1"
								Grid.Row="3"
								CanEdit="True"
								CalculateValueFunction="{Binding FreqFunc3}"
								IsEnabled="{Binding EqualizerEdit3.EqualizerEnable}"
								Value="{Binding EqualizerEdit3.FreqIndex, Mode=TwoWay}"
								SendValue="{Binding EqualizerEdit3.SendFreqIndex, Mode=TwoWay}"
								CommonCommand="{Binding UpdateEqualizerCommand}" />
							<JCustomControls:JSpinner
								CommonCommandParameter="{StaticResource INT_5}"
								ItemsSource="{x:Static ViewModels:Const.Frequence128Strings}"
								HorizontalAlignment="Stretch"
								Grid.Column="1"
