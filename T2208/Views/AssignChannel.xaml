							<i:EventTrigger
								EventName="MouseEnter">
								<i:InvokeCommandAction
									CommandParameter="{StaticResource INT_1}"
									Command="{Binding MouseEnterOtherWithParameterCommand}" />
							</i:EventTrigger>
						</i:Interaction.Triggers>
