				<Grid
					Row="0"
					Width="206">
					<Grid.RowDefinitions>
						<RowDefinition
							Height="20" />
						<RowDefinition
							Height="auto" />
						<RowDefinition
							Height="auto" />
						<RowDefinition
							Height="auto" />
						<RowDefinition
							Height="auto" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition
							Width="3*" />
						<ColumnDefinition
							Width="0.8*" />
					</Grid.ColumnDefinitions>
