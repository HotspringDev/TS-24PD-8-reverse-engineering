<Page
	x:Class="T2208.Views.Page_Ducker"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:om="clr-namespace:Lib.Controls.FFTControl;assembly=Lib.Controls.MyControls"
	xmlns:JCustomControls="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib"
	xmlns:ViewModels="clr-namespace:T2208.ViewModels"
	xmlns:Infos="clr-namespace:T2208.MyInformations"
	xmlns:local="clr-namespace:T2208.Views"
	xmlns:MyUserControls="clr-namespace:T2208.MyUserControls"
	Title="Page_Ducker">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<Style
				x:Key="SliderTitle"
				TargetType="{x:Type TextBlock}">
				<Setter
					Property="Foreground"
					Value="#FFF5DEB3" />
				<Setter
					Property="TextBlock.TextAlignment"
					Value="Center" />
			</Style>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<UniformGrid
		Rows="1">
		<UniformGrid
			Columns="1">
			<Border
				BorderThickness="1"
				BorderBrush="{StaticResource Brush_Stereoscopic}"
				Background="{StaticResource Image_Background}"
				Margin="5">
				<DockPanel>
					<Border
						DockPanel.Dock="Top"
						Margin="5,2"
						BorderBrush="#FFFFFFFF"
						BorderThickness="0,0,0,2">
						<TextBlock
							Foreground="#FFFFFFFF"
							Text="{DynamicResource Str_SourceSelect}" />
					</Border>
					<JCustomControls:ListDisplayer
						HorizontalAlignment="Center"
						VerticalAlignment="Top"
						ItemsSource="{Binding BackgroundGroup}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<JCustomControls:JSwitcher
									Width="80"
									Height="25"
									Margin="3"
									Content="{Binding ChannelName}"
									Command="{Binding Command}" />
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</JCustomControls:ListDisplayer>
				</DockPanel>
			</Border>
			<Border
				BorderThickness="1"
				BorderBrush="{StaticResource Brush_Stereoscopic}"
				Background="{StaticResource Image_Background}"
				Margin="5">
				<DockPanel>
					<Border
						DockPanel.Dock="Top"
						Margin="5,2"
						BorderBrush="#FFFFFFFF"
						BorderThickness="0,0,0,2">
						<TextBlock
							Foreground="#FFFFFFFF"
							Text="{DynamicResource Str_BGMSetting}" />
					</Border>
					<JCustomControls:ListDisplayer
						HorizontalAlignment="Center"
						VerticalAlignment="Top"
						ItemsSource="{Binding VoiceSourceGroup}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<JCustomControls:JSwitcher
									Width="80"
									Height="25"
									Margin="3"
									Content="{Binding ChannelName}"
									Command="{Binding Command}" />
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</JCustomControls:ListDisplayer>
				</DockPanel>
			</Border>
		</UniformGrid>
		<Border
			BorderThickness="1"
			BorderBrush="{StaticResource Brush_Stereoscopic}"
			Background="{StaticResource Image_Background}"
			Margin="5">
			<DockPanel>
				<Border
					DockPanel.Dock="Top"
					Margin="5,2"
					BorderBrush="#FFFFFFFF"
					BorderThickness="0,0,0,2">
					<TextBlock
						Foreground="#FFFFFFFF"
						Text="{DynamicResource Str_DuckingController}" />
				</Border>
				<StackPanel>
					<UniformGrid
						Columns="4"
						Height="200">
						<DockPanel>
							<TextBlock
								DockPanel.Dock="Top"
								Text="{StaticResource Str_Threshold}"
								Style="{StaticResource SliderTitle}" />
							<TextBlock
								DockPanel.Dock="Top" />
							<Label
								DockPanel.Dock="Bottom"
								Width="50"
								HorizontalContentAlignment="Center"
								Content="{Binding ThresholdValue, Converter='{x:Static ViewModels:ConverterProvider.StringListConverter}', ConverterParameter='{x:Static ViewModels:Const.DuckerThresholds}'}" />
							<JCustomControls:JSlider
								Style="{StaticResource Slider_Vertical}"
								Value="{Binding ThresholdValue}" />
						</DockPanel>
						<DockPanel>
							<TextBlock
								DockPanel.Dock="Top"
								Text="{StaticResource Str_Depth}"
								Style="{StaticResource SliderTitle}" />
							<TextBlock
								DockPanel.Dock="Top" />
							<Label
								DockPanel.Dock="Bottom"
								Width="50"
								HorizontalContentAlignment="Center"
								Content="{Binding Depth, Converter='{x:Static ViewModels:ConverterProvider.StringListConverter}', ConverterParameter='{x:Static ViewModels:Const.DuckerDepth}'}" />
							<JCustomControls:JSlider
								Style="{StaticResource Slider_Vertical}" />
						</DockPanel>
						<DockPanel>
							<TextBlock
								DockPanel.Dock="Top"
								Text="{StaticResource Str_Attack}"
								Style="{StaticResource SliderTitle}" />
							<TextBlock
								DockPanel.Dock="Top" />
							<Label
								DockPanel.Dock="Bottom"
								Width="50"
								HorizontalContentAlignment="Center"
								Content="{Binding Attack, Converter='{x:Static ViewModels:ConverterProvider.StringListConverter}', ConverterParameter='{x:Static ViewModels:Const.DuckerAttack}'}" />
							<JCustomControls:JSlider
								Style="{StaticResource Slider_Vertical}" />
						</DockPanel>
						<DockPanel>
							<TextBlock
								DockPanel.Dock="Top"
								Text="{StaticResource Str_Release}"
								Style="{StaticResource SliderTitle}" />
							<TextBlock
								DockPanel.Dock="Top" />
							<Label
								DockPanel.Dock="Bottom"
								Width="50"
								HorizontalContentAlignment="Center"
								Content="{Binding Release, Converter='{x:Static ViewModels:ConverterProvider.StringListConverter}', ConverterParameter='{x:Static ViewModels:Const.DuckerRelease}'}" />
							<JCustomControls:JSlider
								Style="{StaticResource Slider_Vertical}" />
						</DockPanel>
					</UniformGrid>
					<JCustomControls:JSwitcher
						Width="60"
						Height="30"
						Margin="10"
						Content="{DynamicResource Str_Bypass}" />
				</StackPanel>
			</DockPanel>
		</Border>
	</UniformGrid>
</Page>
