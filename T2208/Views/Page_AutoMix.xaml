<Page
	x:Class="T2208.Views.Page_AutoMix"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:om="clr-namespace:Lib.Controls.FFTControl;assembly=Lib.Controls.MyControls"
	xmlns:JCustomControls="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib"
	xmlns:MyConverters="clr-namespace:T2208.MyConverters"
	xmlns:ViewModels="clr-namespace:T2208.ViewModels"
	xmlns:local="clr-namespace:T2208.Views"
	xmlns:MyUserControls="clr-namespace:T2208.MyUserControls"
	Title="Page_AutoMix">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<Style
				x:Key="{x:Type TextBlock}"
				TargetType="{x:Type TextBlock}">
				<Setter
					Property="Foreground"
					Value="#FFFFFFFF" />
				<Setter
					Property="VerticalAlignment"
					Value="Center" />
			</Style>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Border
		BorderThickness="1"
		Background="{StaticResource Image_Background}">
		<Grid
			Margin="9,30,9,0">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="auto" />
				<RowDefinition
					Height="120" />
				<RowDefinition
					Height="67*" />
			</Grid.RowDefinitions>
			<Border
				BorderThickness="1"
				BorderBrush="{StaticResource Brush_Stereoscopic}"
				Background="{StaticResource Image_Background}">
				<DockPanel>
					<Border
						DockPanel.Dock="Top"
						Margin="5,2"
						BorderBrush="#FFFFFFFF"
						BorderThickness="0,0,0,2">
						<TextBlock
							Foreground="#FFFFFFFF"
							Text="{StaticResource Str_SourceSelect}" />
					</Border>
					<JCustomControls:ListDisplayer
						HorizontalAlignment="Center"
						VerticalAlignment="Top"
						ItemsSource="{Binding InputGroup}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate
								DataType="{x:Type ViewModels:ButtonItem}">
								<JCustomControls:JSwitcher
									Width="80"
									Height="25"
									Margin="3"
									Content="{Binding Content}"
									Command="{Binding Command}"
									IsChecked="{Binding IsSelected}" />
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</JCustomControls:ListDisplayer>
				</DockPanel>
			</Border>
			<StackPanel
				Grid.Row="1"
				HorizontalAlignment="Center"
				Orientation="Horizontal">
				<JCustomControls:JSwitcher
					Width="120"
					Height="40"
					Margin="10"
					Content="AutoMix Active"
					IsChecked="{Binding AutoMixActive}"
					Command="{Binding SelectInputMixer}" />
				<Button
					Width="120"
					Height="40"
					Margin="10"
					Content="Clear All"
					Command="{Binding ClearAllCommand}" />
			</StackPanel>
		</Grid>
	</Border>
</Page>
