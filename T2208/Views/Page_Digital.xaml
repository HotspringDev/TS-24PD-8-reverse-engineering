<Page
	x:Class="T2208.Views.Page_Digital"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:JCustomControls="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib"
	xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
	xmlns:ViewModels="clr-namespace:T2208.ViewModels"
	xmlns:Info="clr-namespace:T2208.MyInformations"
	xmlns:MyUserControls="clr-namespace:T2208.MyUserControls"
	Title="Page_Digital"
	xmlns:views="clr-namespace:T2208.Views">
	<Grid>
		<Border
			BorderThickness="1"
			BorderBrush="{StaticResource Brush_Stereoscopic}"
			Background="{StaticResource Image_Background}">
			<DockPanel>
				<Border
					DockPanel.Dock="Top"
					Margin="5,2"
					BorderBrush="#FFFFFFFF"
					BorderThickness="0,0,0,2">
					<TextBlock
						Foreground="#FFFFFFFF"
						TextAlignment="Center"
						FontSize="20"
						Text="{Binding SelectedGroup.GroupName}" />
				</Border>
				<Border
					DockPanel.Dock="Bottom"
					Height="50">
					<DockPanel
						HorizontalAlignment="Right">
						<JCustomControls:JSwitcher
							Name="AllPost"
							Width="80"
							DockPanel.Dock="Left"
							Margin="10"
							Content="{StaticResource Str_AllPost}"
							IsChecked="{Binding AllPost, Mode=TwoWay}"
							Command="{Binding DigitalOutputAllPostChangeCammand}"
							Visibility="{Binding SelectedGroup.HasAllPost, Converter='{x:Static ViewModels:ConverterProvider.BoolToVisibilityConverter}'}" />
						<Button
							Width="80"
							DockPanel.Dock="Left"
							Margin="10"
							Content="Mapping"
							Command="{Binding ShowChannelMappingCommand}" />
						<Rectangle
							Width="2"
							Fill="#FFFFFFFF"
							DockPanel.Dock="Left" />
						<JCustomControls:TabPanelListBox
							Name="SelectGroup"
							Style="{StaticResource TabPanelUniformGrid}"
							ItemsSource="{Binding ChannelGroup}"
							SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
							SelectedIndex="{Binding SelectedIndex}">
							<i:Interaction.Triggers>
								<i:EventTrigger
									EventName="SelectionChanged">
									<i:InvokeCommandAction
										Command="{Binding SelectDigitalGourpCommand}" />
								</i:EventTrigger>
							</i:Interaction.Triggers>
							<ItemsControl.ItemContainerStyle>
								<Style
									BasedOn="{StaticResource TabPanelItemButton}"
									TargetType="{x:Type JCustomControls:TabPanelListBoxItem}">
									<Setter
										Property="Margin"
										Value="5" />
									<Setter
										Property="VerticalContentAlignment"
										Value="Center" />
									<Setter
										Property="Foreground"
										Value="#FFD3D3D3" />
									<Setter
										Property="HorizontalContentAlignment"
										Value="Center" />
								</Style>
							</ItemsControl.ItemContainerStyle>
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Grid>
										<TextBlock
											VerticalAlignment="Center"
											TextAlignment="Center"
											Text="{Binding GroupName}"
											Style="{x:Null}" />
									</Grid>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</JCustomControls:TabPanelListBox>
					</DockPanel>
				</Border>
				<JCustomControls:ListDisplayer
					HorizontalAlignment="Center"
					VerticalAlignment="Top"
					ItemsSource="{Binding SelectedGroup.GroupCollection}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate
							DataType="{x:Type Info:DigitalInfo}">
							<MyUserControls:DigitalBox
								Width="80"
								Margin="15 3 17 4"
								DataContext="{Binding}" />
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</JCustomControls:ListDisplayer>
			</DockPanel>
		</Border>
	</Grid>
</Page>
