<Page
	x:Class="T2208.Views.Page_FBC"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:om="clr-namespace:Lib.Controls.FFTControl;assembly=Lib.Controls.MyControls"
	xmlns:JCustomControls="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib"
	xmlns:ViewModels="clr-namespace:T2208.ViewModels"
	xmlns:local="clr-namespace:T2208.Views"
	xmlns:MyUserControls="clr-namespace:T2208.MyUserControls"
	Title="Page_FBC">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<Style
				x:Key="{x:Type TextBlock}"
				TargetType="{x:Type TextBlock}">
				<Setter
					Property="Foreground"
					Value="#FFFFFFFF" />
				<Setter
					Property="VerticalAlignment"
					Value="Center" />
			</Style>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Border
		BorderThickness="1"
		Background="{StaticResource Image_Background}">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition
					Height="157*" />
				<RowDefinition
					Height="224" />
				<RowDefinition
					Height="67*" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition />
				<ColumnDefinition />
			</Grid.ColumnDefinitions>
			<Border
				BorderThickness="1"
				BorderBrush="{StaticResource Brush_Stereoscopic}"
				Background="{StaticResource Image_Background}">
				<DockPanel>
					<Border
						DockPanel.Dock="Top"
						Margin="5,2"
						BorderBrush="#FFFFFFFF"
						BorderThickness="0,0,0,2">
						<TextBlock
							Foreground="#FFFFFFFF">反馈抑制本地输入</TextBlock>
					</Border>
					<JCustomControls:ListDisplayer
						HorizontalAlignment="Center"
						VerticalAlignment="Top"
						ItemsSource="{Binding InputGroup}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate
								DataType="{x:Type ViewModels:ButtonItem}">
								<JCustomControls:JSwitcher
									Width="80"
									Height="25"
									Margin="3"
									Content="{Binding Content}"
									Command="{Binding Command}" />
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</JCustomControls:ListDisplayer>
				</DockPanel>
			</Border>
			<Border
				BorderThickness="1"
				Grid.Column="1"
				BorderBrush="{StaticResource Brush_Stereoscopic}"
				Background="{StaticResource Image_Background}">
				<DockPanel>
					<Border
						DockPanel.Dock="Top"
						Margin="5,2"
						BorderBrush="#FFFFFFFF"
						BorderThickness="0,0,0,2">
						<TextBlock
							Foreground="#FFFFFFFF">反馈抑制本地输入</TextBlock>
					</Border>
					<JCustomControls:ListDisplayer
						HorizontalAlignment="Center"
						VerticalAlignment="Top"
						ItemsSource="{Binding OutputGroup}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate
								DataType="{x:Type ViewModels:ButtonItem}">
								<JCustomControls:JSwitcher
									Width="80"
									Height="25"
									Margin="3"
									Content="{Binding Content}"
									Command="{Binding Command}" />
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</JCustomControls:ListDisplayer>
				</DockPanel>
			</Border>
			<Grid
				Row="1"
				ColumnSpan="2"
				Margin="0,5,0,0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition />
					<ColumnDefinition />
				</Grid.ColumnDefinitions>
				<Border
					BorderThickness="1"
					Background="{StaticResource Image_Background}">
					<DockPanel>
						<Border
							DockPanel.Dock="Top"
							Margin="5,2"
							BorderBrush="#FFFFFFFF"
							BorderThickness="0,0,0,2">
							<TextBlock
								Foreground="#FFFFFFFF">反馈抑制本地输入</TextBlock>
						</Border>
						<StackPanel
							Orientation="Horizontal"
							DockPanel.Dock="Top"
							HorizontalAlignment="Center"
							Margin="5"
							Height="40">
							<TextBlock>FBC 模式</TextBlock>
							<JCustomControls:JSpinner
								Height="25" />
							<TextBlock>释放滤波器</TextBlock>
							<JCustomControls:JSpinner
								Height="25" />
						</StackPanel>
						<Border
							DockPanel.Dock="Top"
							BorderThickness="1"
							Margin="10"
							BorderBrush="#FF808080" />
						<StackPanel
							DockPanel.Dock="Top"
							Orientation="Horizontal"
							HorizontalAlignment="Center">
							<Label
								Width="50"
								Margin="10,0"
								Height="30" />
							<JCustomControls:JSlider
								Width="150"
								Style="{StaticResource Slider_Horizontal}"
								ThumbImage="{StaticResource Image_GraySliderThumb}"
								ThumbImageWidth="25"
								ThumbImageHeight="20" />
						</StackPanel>
						<StackPanel
							DockPanel.Dock="Top"
							Orientation="Horizontal"
							HorizontalAlignment="Center"
							Height="50">
							<JCustomControls:JSwitcher
								Content="静态滤波器设置"
								Width="110"
								Margin="5" />
							<Button
								Content="清除动态滤波器"
								Width="110"
								Margin="5" />
							<Button
								Content="清除所有滤波器"
								Width="110"
								Margin="5" />
							<JCustomControls:JSwitcher
								Content="旁路"
								Width="110"
								Margin="5" />
						</StackPanel>
					</DockPanel>
				</Border>
				<Border
					Background="{StaticResource Image_Background}"
					BorderThickness="1,1,0,1"
					Grid.Column="1"
					Padding="30,20,20,20"
					Margin="1">
					<om:FBCFFTDraw
						x:Name="fbcFFTDraw"
						xmlns:controls="clr-namespace:Lib.Controls;assembly=Lib.Controls.MyControls"
						BackBrush="Black" />
				</Border>
			</Grid>
			<JCustomControls:ListDisplayer
				Grid.ColumnSpan="2"
				Grid.Row="2"
				Margin="10,0"
				ItemsSource="{Binding FBCLights}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<UniformGrid
							Rows="1" />
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate
						DataType="{x:Type ViewModels:FBCLightItem}">
						<MyUserControls:FBCLight
							Height="40"
							Width="40"
							DataContext="{Binding}" />
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</JCustomControls:ListDisplayer>
		</Grid>
	</Border>
</Page>
