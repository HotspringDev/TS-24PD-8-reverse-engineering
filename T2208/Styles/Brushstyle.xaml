<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<LinearGradientBrush
		x:Key="Brush_Normal"
		EndPoint="0.5,1"
		StartPoint="0.5,0">
		<GradientBrush.GradientStops>
			<GradientStop
				Color="#50ffffff"
				Offset="0" />
			<GradientStop
				Color="#50000000"
				Offset="1" />
		</GradientBrush.GradientStops>
	</LinearGradientBrush>
	<LinearGradientBrush
		x:Key="Brush_MouseOver"
		EndPoint="0.5,1"
		StartPoint="0.5,0">
		<GradientBrush.GradientStops>
			<GradientStop
				Color="#B0ffffff"
				Offset="0" />
			<GradientStop
				Color="#40808080"
				Offset="1" />
		</GradientBrush.GradientStops>
	</LinearGradientBrush>
	<SolidColorBrush
		x:Key="Brush_Black"
		Color="#ff404040" />
</ResourceDictionary>
