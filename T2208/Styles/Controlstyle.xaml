	<Style
		x:Key="TabPanelItemButton"
		TargetType="{x:Type JCustomControls:TabPanelListBoxItem}">
		<Setter
			Property="Template">
			<Setter.Value>
				<ControlTemplate
					TargetType="{x:Type JCustomControls:TabPanelListBoxItem}">
					<Grid
						Width="{TemplateBinding FrameworkElement.Width}"
						Height="{TemplateBinding FrameworkElement.Height}"
						Margin="{TemplateBinding FrameworkElement.Margin}">
						<AdornerDecorator>
							<Border
								Name="BD"
								CornerRadius="3"
								Effect="{DynamicResource Effect_Normal}"
								Background="{TemplateBinding Control.Background}" />
						</AdornerDecorator>
						<Border
							Name="styleBorder"
							Width="{TemplateBinding FrameworkElement.Width}"
							Background="{StaticResource Brush_Stereoscopic}"
							CornerRadius="{Binding ElementName=BD, Path=CornerRadius}">
							<ContentPresenter
								HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
								RecognizesAccessKey="True"
								SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"
								VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}" />
						</Border>
					</Grid>
					<ControlTemplate.Triggers>
						<Trigger
							Property="IsEnabled"
							Value="False">
							<Setter
								Property="UIElement.Opacity"
								Value="0.23" />
							<Setter
								TargetName="BD"
								Property="UIElement.Effect"
								Value="{x:Null}" />
						</Trigger>
						<Trigger
							Property="ListBoxItem.IsSelected"
							Value="True">
							<Setter
								Property="Background"
								Value="#FF32CD32" />
							<Setter
								Property="Foreground"
								Value="#FFFFFFFF" />
							<Setter
								TargetName="BD"
								Property="UIElement.Effect">
								<Setter.Value>
									<DropShadowEffect
										BlurRadius="2"
										Direction="-90"
										Opacity="0.6"
										ShadowDepth="2" />
								</Setter.Value>
							</Setter>
						</Trigger>
						<MultiTrigger>
							<MultiTrigger.Conditions>
								<Condition
									Property="JCustomControls:TabPanelListBoxItem.IsPressed"
									Value="False" />
								<Condition
									Property="UIElement.IsMouseOver"
									Value="True" />
							</MultiTrigger.Conditions>
							<Setter
								TargetName="styleBorder"
								Property="Border.Background"
								Value="{StaticResource Brush_Stereoscopic}" />
						</MultiTrigger>
						<Trigger
							Property="UIElement.IsMouseOver"
							Value="True">
							<Setter
								TargetName="styleBorder"
								Property="Border.Background"
								Value="{StaticResource Brush_Stereoscopic}" />
						</Trigger>
						<MultiTrigger>
							<MultiTrigger.Conditions>
								<Condition
									Property="JCustomControls:TabPanelListBoxItem.IsPressed"
									Value="True" />
								<Condition
									Property="UIElement.IsMouseOver"
									Value="True" />
							</MultiTrigger.Conditions>
							<Setter
								Property="Foreground"
								Value="#FFFFFFFF" />
							<Setter
								Property="Padding"
								Value="2,3,2,2" />
							<Setter
								TargetName="BD"
								Property="UIElement.Effect">
								<Setter.Value>
									<DropShadowEffect
										BlurRadius="2"
										Direction="-90"
										Opacity="0.6"
										ShadowDepth="1.5" />
								</Setter.Value>
							</Setter>
						</MultiTrigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
