<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:oc="clr-namespace:Lib.Controls;assembly=Lib.Controls.MyControls"
	xmlns:JCustomControls="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib">
	<DropShadowEffect
		x:Key="Effect_Normal"
		BlurRadius="2"
		Direction="-90"
		Opacity="0.6"
		ShadowDepth="3" />
	<DropShadowEffect
		x:Key="Effect_IsChecked"
		BlurRadius="2"
		Direction="-90"
		Opacity="0.6"
		ShadowDepth="2" />
	<DropShadowEffect
		x:Key="Cs_checkbox_effect"
		BlurRadius="2"
		Direction="-90"
		Opacity="0.4"
		ShadowDepth="2" />
	<DropShadowEffect
		x:Key="Effect_IsPressed"
		BlurRadius="2"
		Direction="-90"
		Opacity="0.6"
		ShadowDepth="1.5" />
	<LinearGradientBrush
		x:Key="Brush_Stereoscopic"
		EndPoint="0.5,1"
		StartPoint="0.5,0">
		<GradientBrush.GradientStops>
			<GradientStop
				Color="#50ffffff"
				Offset="0" />
			<GradientStop
				Color="#50000000"
				Offset="1" />
		</GradientBrush.GradientStops>
	</LinearGradientBrush>
	<Style
		x:Key="Btn_Exit"
		TargetType="{x:Type Button}">
		<Setter
			Property="Template">
			<Setter.Value>
				<ControlTemplate
					TargetType="{x:Type Button}">
					<Grid
						Name="GD">
						<ContentPresenter />
						<Image
							Source="{StaticResource Image_Exit}" />
						<Border
							Name="Brd"
							CornerRadius="20"
							Background="{StaticResource Brush_Normal}" />
					</Grid>
					<ControlTemplate.Triggers>
						<MultiTrigger>
							<MultiTrigger.Conditions>
								<Condition
									Property="IsPressed"
									Value="True" />
								<Condition
									Property="UIElement.IsMouseOver"
									Value="True" />
							</MultiTrigger.Conditions>
							<Setter
								TargetName="GD"
								Property="Margin"
								Value="0 3 0 -3" />
						</MultiTrigger>
						<Trigger
							Property="UIElement.IsMouseOver"
							Value="True">
							<Setter
								TargetName="Brd"
								Property="Border.Background"
								Value="{StaticResource Brush_MouseOver}" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<Style
		x:Key="TopNaviGationBar"
		TargetType="{x:Type JCustomControls:ListDisplayer}">
		<Setter
			Property="ItemsPanel">
			<Setter.Value>
				<ItemsPanelTemplate>
					<UniformGrid
						Rows="1" />
				</ItemsPanelTemplate>
			</Setter.Value>
		</Setter>
		<Setter
			Property="Template">
			<Setter.Value>
				<ControlTemplate
					TargetType="{x:Type JCustomControls:ListDisplayer}">
					<Border
						HorizontalAlignment="Stretch"
						Padding="{TemplateBinding Control.Padding}"
						Width="{TemplateBinding FrameworkElement.Width}"
						Height="{TemplateBinding FrameworkElement.Height}"
						Background="{TemplateBinding Control.Background}">
						<ItemsPresenter />
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<Style
		x:Key="Switcher_Channel"
		TargetType="{x:Type JCustomControls:JSwitcher}">
		<Setter
			Property="FrameworkElement.Cursor"
			Value="Hand" />
		<Setter
			Property="JCustomControls:JSwitcher.ActiveBackgroundBrush"
			Value="#FF32CD32" />
		<Setter
			Property="JCustomControls:JSwitcher.InactiveBackgroundBrush"
			Value="#FF808080" />
		<Setter
			Property="FontFamily"
			Value="Segoe UI, Lucida Sans Unicode, Verdana" />
		<Setter
			Property="JCustomControls:JSwitcher.ActiveForegroundBrush"
			Value="#FFFFFFFF" />
		<Setter
			Property="JCustomControls:JSwitcher.InactiveForegroundBrush"
			Value="#FF000000" />
		<Setter
			Property="JCustomControls:JSwitcher.CanEdit"
			Value="False" />
		<Setter
			Property="Template">
			<Setter.Value>
				<ControlTemplate
					TargetType="{x:Type JCustomControls:JSwitcher}">
					<Grid
						Name="GD">
						<Border
							x:Name="BD"
							CornerRadius="3"
							Effect="{DynamicResource Effect_Normal}"
							Background="{TemplateBinding Control.Background}" />
						<Grid>
							<ContentControl
								Margin="{TemplateBinding Control.Padding}"
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								Content="{TemplateBinding ContentControl.Content}" />
							<TextBox
								Name="PART_TextBox"
								Foreground="{TemplateBinding Control.Foreground}"
								BorderThickness="0"
								Margin="1"
								Visibility="Collapsed"
								TextAlignment="Center"
								Text="{Binding Path=InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=JCustomControls:JSwitcher}}" />
						</Grid>
						<Border
							Name="styleBorder"
							Background="{DynamicResource Brush_Stereoscopic}"
							IsHitTestVisible="False"
							CornerRadius="{Binding ElementName=BD, Path=CornerRadius}" />
					</Grid>
					<ControlTemplate.Triggers>
						<Trigger
							Property="JCustomControls:JSwitcher.IsEditing"
							Value="True">
							<Setter
								TargetName="PART_TextBox"
								Property="Visibility"
								Value="Visible" />
						</Trigger>
						<Trigger
							Property="ToggleButton.IsChecked"
							Value="true">
							<Setter
								TargetName="GD"
								Property="Margin"
								Value="0 1 0 -1" />
							<Setter
								Property="Foreground"
								Value="#FFFFFFFF" />
							<Setter
								TargetName="BD"
								Property="UIElement.Effect"
								Value="{StaticResource Effect_IsChecked}" />
						</Trigger>
						<Trigger
							Property="IsEnabled"
							Value="False">
							<Setter
								Property="UIElement.Opacity"
								Value="0.50" />
							<Setter
								TargetName="BD"
								Property="UIElement.Effect"
								Value="{x:Null}" />
						</Trigger>
						<Trigger
							Property="IsPressed"
							Value="True">
							<Setter
								Property="Foreground"
								Value="#FFFFFFFF" />
							<Setter
								TargetName="GD"
								Property="Margin"
								Value="0 1.5 0 -1.5" />
							<Setter
								TargetName="BD"
								Value="{DynamicResource Effect_IsPressed}"
								Property="UIElement.Effect" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<Style
		x:Key="Switcher_Normal"
		TargetType="{x:Type JCustomControls:JSwitcher}"
		BasedOn="{StaticResource Switcher_Channel}">
		<Setter
