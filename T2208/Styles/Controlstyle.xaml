							<Track.IncreaseRepeatButton>
								<RepeatButton
									x:Name="PageUp"
									Visibility="Hidden"
									Focusable="False" />
							</Track.IncreaseRepeatButton>
							<Track.DecreaseRepeatButton>
								<RepeatButton
									x:Name="PageDown"
									Visibility="Hidden"
									Focusable="False" />
							</Track.DecreaseRepeatButton>
