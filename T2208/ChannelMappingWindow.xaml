<Window
	x:Class="T2208.ChannelMappingWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:JControls="clr-namespace:JayCustomControlLib;assembly=JayCustomControlLib"
	xmlns:ViewModels="clr-namespace:T2208.ViewModels"
	xmlns:local="clr-namespace:T2208"
	WindowStyle="ToolWindow"
	Background="{StaticResource Image_Background}"
	Title="Channel Mapping"
	WindowStartupLocation="CenterOwner"
	Topmost="True"
	ResizeMode="NoResize"
	SizeToContent="WidthAndHeight"
	DataContext="{Binding Source='{x:Static ViewModels:ViewModelLocator.ChannelMappingViewModel}'}">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<Style
				x:Key="{x:Type TextBlock}"
				TargetType="{x:Type TextBlock}">
				<Setter
					Property="TextBlock.TextAlignment"
					Value="Center" />
			</Style>
			<Style
				x:Key="{x:Type JControls:ListDisplayer}"
				TargetType="{x:Type JControls:ListDisplayer}">
				<Setter
					Property="Background"
					Value="#00FFFFFF" />
				<Setter
					Property="Foreground"
					Value="#FFFFFFFF" />
				<Setter
					Property="ItemContainerStyle">
					<Setter.Value>
						<Style
							TargetType="{x:Type JControls:ListDisplayItem}">
							<Setter
								Property="Template">
								<Setter.Value>
									<ControlTemplate
										TargetType="{x:Type JControls:ListDisplayItem}">
										<Border
											BorderThickness="1"
											BorderBrush="#FFFFFFFF"
											Padding="5,3,5,3">
											<ContentPresenter
												HorizontalAlignment="Center"
												Margin="1"
												VerticalAlignment="Center" />
										</Border>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</Setter.Value>
				</Setter>
				<Setter
					Property="ItemsPanel">
					<Setter.Value>
						<ItemsPanelTemplate>
							<UniformGrid
								Columns="1" />
						</ItemsPanelTemplate>
					</Setter.Value>
				</Setter>
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type JControls:ListDisplayer}">
							<Border
								HorizontalAlignment="Stretch"
								Padding="{TemplateBinding Control.Padding}"
								Width="{TemplateBinding FrameworkElement.Width}"
								Height="{TemplateBinding FrameworkElement.Height}"
								Background="{TemplateBinding Control.Background}">
								<ItemsPresenter />
							</Border>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style
				x:Key="{x:Type JControls:ListDisplayItem}"
				TargetType="{x:Type JControls:ListDisplayItem}">
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type JControls:ListDisplayItem}">
							<Border
								BorderThickness="1"
								BorderBrush="#FFFFFFFF">
								<ContentPresenter
									HorizontalAlignment="Center"
									Margin="1" />
							</Border>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Grid
		Name="grid"
		HorizontalAlignment="Center">
		<Grid.ColumnDefinitions>
			<ColumnDefinition
				Width="auto" />
			<ColumnDefinition
				Width="auto" />
			<ColumnDefinition
				Width="auto" />
			<ColumnDefinition
				Width="auto" />
		</Grid.ColumnDefinitions>
		<JControls:ListDisplayer
			Grid.Column="0"
			ItemsSource="{Binding Column1}" />
		<JControls:ListDisplayer
			Grid.Column="1"
			ItemsSource="{Binding Column2}" />
		<JControls:ListDisplayer
			Grid.Column="2"
			ItemsSource="{Binding Column3}" />
		<JControls:ListDisplayer
			Grid.Column="3"
			ItemsSource="{Binding Column4}" />
	</Grid>
</Window>
